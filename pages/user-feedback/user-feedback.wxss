/* pages/user-feedback/user-feedback.wxss */
.container {
  padding: 32rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 头部区域 */
.header {
  margin-bottom: 48rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 问题区域 */
.question-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.question-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  line-height: 1.4;
}

/* 评分区域 */
.score-container {
  margin-top: 24rpx;
}

.score-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.score-label {
  font-size: 24rpx;
  color: #999;
}

.score-buttons {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.score-button {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
  background-color: #f0f0f0;
  color: #666;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
  border: none;
}

.score-button.selected {
  background-color: #07c160;
  color: #fff;
}

.current-score {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.score-value {
  font-weight: bold;
  color: #07c160;
  font-size: 32rpx;
}

/* 选项区域 */
.options-container {
  margin-top: 6rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 0rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background-color: #f8f9fa;
  transition: background-color 0.2s;
}

.option-item.selected {
  background-color: #e8f5e9;
  border-left: 6rpx solid #07c160;
}

.option-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-item.selected .option-radio {
  border-color: #07c160;
}

.radio-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #07c160;
}

.option-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

/* 错误提示 */
.error-message {
  background-color: #ffebee;
  color: #d32f2f;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

/* 按钮区域 */
.button-container {
  margin-top: 48rpx;
  padding: 32rpx 0;
}

.submit-button {
  background-color: #07c160;
  color: #fff;
  font-size: 32rpx;
  height: 88rpx;
  border-radius: 44rpx;
  line-height: 88rpx;
  margin-bottom: 24rpx;
}

.submit-button[disabled] {
  background-color: #b2dfb2 !important;
  color: #fff !important;
  opacity: 0.7;
}

.skip-button {
  background-color: transparent;
  color: #666;
  font-size: 28rpx;
  border: none;
  padding: 20rpx 0;
}

.skip-button[disabled] {
  opacity: 0.5;
}

/* 进度提示 */
.progress-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 32rpx;
  padding: 16rpx;
  background-color: #f0f9ff;
  border-radius: 12rpx;
  border: 1rpx solid #d0ebff;
}